# TrishulHub Main Site — environment variable template
# Copy this file to .env (local dev) or set the same keys in your Vercel dashboard.

# ──────────────────────────────────────────────────────────────
# DATABASE_URL — what Prisma's datasource validator sees.
# Must start with `file:`. The libsql adapter intercepts every
# query and routes it to Turso, so this placeholder is never
# actually queried at runtime.
# ──────────────────────────────────────────────────────────────
DATABASE_URL=file:placeholder.db

# ──────────────────────────────────────────────────────────────
# TURSO_DATABASE_URL — the actual remote DB URL the libsql
# adapter connects to. Must start with `libsql://`.
# ──────────────────────────────────────────────────────────────
TURSO_DATABASE_URL=libsql://your-db-name-here.turso.io

# ──────────────────────────────────────────────────────────────
# TURSO_AUTH_TOKEN — required by Turso for authentication.
# Generate via:  turso db tokens create <db-name>
# ──────────────────────────────────────────────────────────────
TURSO_AUTH_TOKEN=

# Backwards-compat alias (older scripts may still look this up).
DATABASE_AUTH_TOKEN=
