# DATABASE_URL — what Prisma's datasource validator sees.
# Must start with `file:`. The adapter intercepts every query and routes
# it to Turso, so this placeholder is never actually queried.
DATABASE_URL=file:placeholder.db

# TURSO_DATABASE_URL — the actual remote DB the libsql adapter connects to.
TURSO_DATABASE_URL=libsql://trishulhub-main-site-trishulhub-svg.aws-eu-west-1.turso.io

# TURSO_AUTH_TOKEN — required by Turso for authentication.
